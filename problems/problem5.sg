fun mdc(n, m: int, ref r: int): none {
  if (m % n == 0) {
    r = n;
    return;
  }

  if (n % m == 0) {
    r = m;
    return;
  }

  if (m > n) {
    mdc(n, m % n, r);
    return;
  }

  mdc(m, n % m, r);
}

fun main(): none {
  print("Valor de N:");
  n: int = int(read());

  print("Valor de M:");
  m: int = int(read());

