{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Sigma",
  "patterns": [
    {
      "name": "keyword.control.sigma",
      "match": "\\b(if|else|while|for|return)\\b"
    },
    {
      "match": "\\b(fun)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captures": {
        "1": {
          "name": "keyword.declaration.sigma"
        },
        "2": {
          "name": "entity.name.function.sigma"
        }
      }
    },
    {
      "name": "storage.type.sigma",
      "match": "\\b(int|float|bool|string|none)\\b"
    },
    {
      "name": "support.function.sigma",
      "match": "\\b(print|read|matrizFloat|matrizInt|matrizBool|matrizString)\\b"
    },
    {
      "name": "entity.name.function.sigma",
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
    },
    {
      "name": "constant.language.boolean.sigma",
      "match": "\\b(true|false)\\b"
    },
    {
      "name": "constant.numeric.sigma",
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
    },
    {
      "name": "comment.line.double-slash.sigma",
      "match": "//.*$"
    },
    {
      "name": "string.quoted.double.sigma",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.sigma",
          "match": "\\\\."
        }
      ]
    },
    {
      "name": "keyword.operator.sigma",
      "match": "(==|!=|<=|>=|<|>|\\+|-|\\*|/|%|\\*\\*|\\+\\+|=)"
    }
  ],
  "scopeName": "source.sigma"
}
